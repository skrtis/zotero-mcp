# Zotero MCP Server — Environment Variables
# Copy this file to .env and fill in your values.

# Your Zotero library ID.
# Find it at: https://www.zotero.org/settings/keys
# For a user library it's the number in your profile URL (e.g. 1234567).
ZOTERO_LIBRARY_ID=

# Your Zotero API key.
# Create one at: https://www.zotero.org/settings/keys/new
# Grant read access (and write access if you want create_note / add_item_by_doi).
ZOTERO_API_KEY=

# "user" for a personal library, "group" for a group library.
ZOTERO_LIBRARY_TYPE=user

# Set to "true" to use the local Zotero app API (port 23119) instead of the web API.
# Local mode enables full-text extraction and annotation access.
# Requires Zotero to be open on this machine with "Allow other applications to access Zotero" enabled.
ZOTERO_LOCAL=false
